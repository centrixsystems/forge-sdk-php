{
    "name": "centrix/forge-sdk",
    "description": "PHP SDK for the Forge rendering engine",
    "type": "library",
    "license": "MIT",
    "keywords": ["forge", "pdf", "rendering", "html", "screenshot"],
    "homepage": "https://github.com/centrixsystems/forge-sdk-php",
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Centrix\\Forge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Centrix\\Forge\\Tests\\": "tests/"
        }
    }
}
